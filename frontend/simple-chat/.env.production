VITE_BACKEND_URI=/api

# --------------------------------------------------------------------------
# Foundry agent — non-secret config exposed to the browser.
# Secrets (FOUNDRY_ENDPOINT / FOUNDRY_API_KEY) are injected by the nginx
# `/foundry` proxy at runtime (see nginx/nginx.conf.template).
# --------------------------------------------------------------------------
VITE_FOUNDRY_AGENT=case-assistant-agent
VITE_FOUNDRY_API_VERSION=

# SharePoint sites for the dropdown (comma-separated display names).
VITE_SHAREPOINT_SITES=Contoso HR,Contoso IT,Contoso Legal

