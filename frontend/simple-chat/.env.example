# ==========================================================================
# simple-chat environment configuration
# Copy this file to `.env.local` (git-ignored) and fill in real values.
# ==========================================================================

# --------------------------------------------------------------------------
# Foundry agent (server-side — NOT exposed to the browser bundle)
# Auth is injected by the Vite dev-server proxy / nginx so no secret or token
# ever ships in client JavaScript.
#
# Local dev preferred auth: the developer identity from `az login`
# (DefaultAzureCredential). Just run `az login` with an account that has
# access to the Foundry resource — no key required.
# --------------------------------------------------------------------------
# Base URL of the Foundry / Azure OpenAI resource that exposes the
# Responses API, e.g. https://my-resource.openai.azure.com
FOUNDRY_ENDPOINT=
# Optional fallback API key. Only used if an AAD token could not be acquired
# (e.g. you are not logged in via `az login`). Leave blank to require AAD auth.
FOUNDRY_API_KEY=
# Path prefix on the resource that exposes the Responses API.
# Defaults to /openai/v1 (OpenAI-compatible v1 surface).
FOUNDRY_PATH_PREFIX=/openai/v1

# --------------------------------------------------------------------------
# Foundry agent (non-secret — safe to expose to the browser)
# --------------------------------------------------------------------------
# The Foundry agent name / id (or model deployment name) to prompt.
VITE_FOUNDRY_AGENT=case-assistant-chat-agent
# Optional API version query string for the Responses API.
# Leave empty when using the version-less /openai/v1 surface.
VITE_FOUNDRY_API_VERSION=

# --------------------------------------------------------------------------
# SharePoint sites shown in the dropdown (comma-separated display names).
# --------------------------------------------------------------------------
VITE_SHAREPOINT_SITES=Contoso HR,Contoso IT,Contoso Legal
