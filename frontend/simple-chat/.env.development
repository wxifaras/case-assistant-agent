# Development environment configuration
# Backend URI for local development (legacy chat API — unused by the Foundry flow)
VITE_BACKEND_URI=http://localhost:8000

# --------------------------------------------------------------------------
# Foundry agent — server-side secrets (injected by the Vite proxy, see
# vite.config.ts). Override these in `.env.local` (git-ignored).
# --------------------------------------------------------------------------
FOUNDRY_ENDPOINT=https://your-foundry-resource.openai.azure.com
FOUNDRY_API_KEY=your-foundry-api-key
FOUNDRY_PATH_PREFIX=/openai/v1

# --------------------------------------------------------------------------
# Foundry agent — non-secret config exposed to the browser.
# --------------------------------------------------------------------------
VITE_FOUNDRY_AGENT=case-assistant-agent
VITE_FOUNDRY_API_VERSION=

# SharePoint sites for the dropdown (comma-separated display names).
VITE_SHAREPOINT_SITES=Contoso HR,Contoso IT,Contoso Legal
