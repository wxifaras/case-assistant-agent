# ============================================================================
# Case Assistant Agent - Environment Configuration
# ============================================================================
# This file contains all environment variables for the Case Assistant Agent application.
#
# NAMING CONVENTION:
# - Uses Pydantic best practice: CATEGORY_SETTING_NAME (single underscore)
# - Example: SEARCHSERVICE_ENDPOINT, AZURE_OPENAI_DEPLOYMENT_NAME
#
# AUTHENTICATION:
# - For production: Set USE_MANAGED_IDENTITY=true and remove API keys
# - For development: Set USE_MANAGED_IDENTITY=false and provide API keys
#
# INSTRUCTIONS:
# 1. Copy this file to .env in the same directory
# 2. Replace placeholder values with your actual Azure resource details
# 3. Remove or comment out optional settings you don't need
## ============================================================================

# ============================================================================
# GENERAL SETTINGS
# ============================================================================
ENVIRONMENT=development
USE_MANAGED_IDENTITY=true

# ============================================================================
# AZURE APP CONFIGURATION (Bootstrap)
# ============================================================================
# When APP_CONFIG_ENDPOINT is set, all other settings below can be stored in
# the App Configuration store instead of this file.  The store is loaded once
# at startup; values there override .env values for the same keys.
#
# KEY NAMING IN THE STORE:
#   Store keys follow the same naming convention as the env vars below,
#   optionally prefixed (e.g. "case-assistant-agent:SEARCHSERVICE_ENDPOINT").
#   Set APP_CONFIG_KEY_FILTER to match that prefix (e.g. "case-assistant-agent:*")
#   and the prefix is stripped automatically so trimmed keys match env var names.
#
# AUTHENTICATION:
#   Set APP_CONFIG_ENDPOINT; uses DefaultAzureCredential (managed identity in Azure,
#   Azure CLI login locally — run 'az login' once).
#
# SECRETS:
#   Store API keys and connection strings as Key Vault references in App Config:
#   { "uri": "https://<vault>.vault.azure.net/secrets/<secret-name>" }
#   They are resolved automatically when using managed identity (endpoint-based auth).
#
# LABELS (environment overlays):
#   Store shared defaults with no label; environment-specific values with a label
#   (e.g. "production").  The label is resolved in order:
#     1. APP_CONFIG_LABEL_FILTER  — explicit override
#     2. ENVIRONMENT              — general environment name (development / staging / production)
#     3. (no label)               — shared keys only
#   Labeled values overlay no-label defaults (last match wins).
#
# Set APP_CONFIG_ENDPOINT to enable.
# Leave unset to load all settings from env vars / this file (default).
APP_CONFIG_ENABLED=false
APP_CONFIG_ENDPOINT=https://<your-store>.azconfig.io
APP_CONFIG_KEY_FILTER=case-assistant-agent:*
# APP_CONFIG_LABEL_FILTER=  # optional: defaults to ENVIRONMENT value
# Enable dynamic refresh polling for App Configuration values
APP_CONFIG_REFRESH_ENABLED=false
# Polling interval in seconds when refresh is enabled
APP_CONFIG_REFRESH_INTERVAL_SECONDS=30


# ============================================================================
# AZURE SERVICES
# ============================================================================

# --- Azure AI Search ---
SEARCHSERVICE_ENDPOINT=https://<your-search-service>.search.windows.net
SEARCHSERVICE_API_KEY=<your-search-api-key>
SEARCHSERVICE_SKILLSET_API_VERSION=2025-08-01-preview
SEARCHSERVICE_INDEX_NAME=case-assistant-agent-content-index
SEARCHSERVICE_DATA_SOURCE_NAME=case-assistant-agent-content-datasource
SEARCHSERVICE_SKILLSET_NAME=case-assistant-agent-content-skillset
SEARCHSERVICE_INDEXER_NAME=case-assistant-agent-content-indexer
SEARCHSERVICE_MARKDOWN_SKILLSET_NAME=case-assistant-agent-content-markdown-skillset
SEARCHSERVICE_MARKDOWN_INDEXER_NAME=case-assistant-agent-content-markdown-indexer
SEARCHSERVICE_JSON_SKILLSET_NAME=case-assistant-agent-content-json-skillset
SEARCHSERVICE_JSON_INDEXER_NAME=case-assistant-agent-content-json-indexer
# Minimum reranker score (0-4) to retain a result when semantic ranking is enabled
SEARCHSERVICE_MIN_RERANKER_SCORE=2.0

# --- Azure Blob Storage ---
BLOBSTORAGE_RESOURCE_ID=/subscriptions/<subscription-id>/resourceGroups/<rg>/providers/Microsoft.Storage/storageAccounts/<account>
BLOBSTORAGE_CONTAINER_NAME=documents
BLOBSTORAGE_IMAGES_CONTAINER_NAME=normalized-images
# OR use connection string for key-based authentication (alternative to ResourceId)
# BLOBSTORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net

# --- Azure AI Services ---
AISERVICES_COGNITIVE_SERVICES_ENDPOINT=https://<your-cognitive-service>.cognitiveservices.azure.com/
# Optional: Use API key for key-based authentication (if not set, uses managed identity)
# AISERVICES_COGNITIVE_SERVICES_KEY=<your-cognitive-services-key>

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com/
# Ensure you comment this out if you have USE_MANAGED_IDENTITY=true
# AZURE_OPENAI_API_KEY=<your-openai-key>
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_TEMPERATURE=0.0
AZURE_OPENAI_MAX_TOKENS=4096
AZURE_OPENAI_MAX_CONTEXT_TOKENS=128000

# Separate endpoint for chat completion (e.g., Azure AI Foundry)
AZURE_OPENAI_CHAT_COMPLETION_RESOURCE_URI=https://<foundry-endpoint>.cognitiveservices.azure.com/openai/deployments/<model>/chat/completions?api-version=2025-01-01-preview
# AZURE_OPENAI_CHAT_COMPLETION_API_KEY=<your-chat-completion-key>

# Optional: Separate endpoint for image verbalization in the skillset
# Falls back to AZURE_OPENAI_CHAT_COMPLETION_RESOURCE_URI if not set
# AZURE_OPENAI_IMAGE_CHAT_COMPLETION_RESOURCE_URI=https://<foundry-endpoint>.cognitiveservices.azure.com/openai/deployments/<image-model>/chat/completions?api-version=2025-01-01-preview

# --- Azure Cosmos DB NoSQL (Conversation History) ---
# AUTHENTICATION OPTIONS:
# Option 1 (RECOMMENDED - Production): RBAC with Managed Identity
#   - Set COSMOS_ENDPOINT only
#   - Do NOT set COSMOS_CONNECTION_STRING
#   - REQUIRES data plane RBAC role assignment:
#     1. Get your managed identity principal ID:
#        az identity show --name <identity-name> --resource-group <rg> --query principalId -o tsv
#        OR for App Service:
#        az webapp identity show --name <app-name> --resource-group <rg> --query principalId -o tsv
#     2. Assign "Cosmos DB Built-in Data Contributor" role:
#        az cosmosdb sql role assignment create \
#          --account-name <cosmos-account> \
#          --resource-group <resource-group> \
#          --role-definition-name "Cosmos DB Built-in Data Contributor" \
#          --principal-id <principal-id-from-step-1> \
#          --scope "/"
#     3. Wait ~5 minutes for role assignment to propagate
# Option 2 (Dev/Test Only): Connection String
#   - Set COSMOS_CONNECTION_STRING with AccountEndpoint and AccountKey
#   - COSMOS_ENDPOINT is ignored if CONNECTION_STRING is provided
#
COSMOS_ENDPOINT=https://your-cosmosdb.documents.azure.com:443/
# COSMOS_CONNECTION_STRING=AccountEndpoint=https://your-cosmosdb.documents.azure.com:443/;AccountKey=<key>==;
COSMOS_DATABASE_NAME=case-assistant-agent-db
COSMOS_CONTAINER_NAME=case-assistant-agent-container
COSMOS_ENABLE_TTL=true
COSMOS_DEFAULT_TTL_DAYS=30

# --- Azure Key Vault (Optional - For Secrets Management) ---
KEYVAULT_URL=https://your-keyvault.vault.azure.net/
KEYVAULT_USE_KEY_VAULT=false

# --- Microsoft Foundry Project Endpoint ---
FOUNDRY_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com
FOUNDRY_AGENT_ENABLED=false
FOUNDRY_AGENT_NAME=case-assistant-agent
FOUNDRY_MODEL=gpt-4.1
FOUNDRY_AGENT_TIMEOUT_SECONDS=90
AGENT_YAML_PATH=backend/app/agents/case_assistant_agent.yaml

# MAF Observability Settings (see: https://deepwiki.com/microsoft/agent-framework/3.6-observability-and-monitoring)
# ENABLE_SENSITIVE_DATA - Include prompts, tool arguments, and results in traces
# WARNING: Only enable in dev/lab environments - DO NOT use in production with real user data
ENABLE_SENSITIVE_DATA=true

# Direct Application Insights connection
# Connection string for Azure Monitor (includes instrumentation key, ingestion, and live metrics endpoints)
# If neither is set, telemetry is disabled (console logging only)
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;IngestionEndpoint=https://xxx.applicationinsights.azure.com/;LiveEndpoint=https://xxx.livediagnostics.monitor.azure.com/
# Enable Application Insights telemetry export
APPINSIGHTS_ENABLED=true

# ============================================================================
# API SERVER SETTINGS
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RATE_LIMIT_PER_MINUTE=60
API_ENABLE_AUTH=false
API_ENABLE_CORS=true
API_ENABLE_DOCS=true


# --- Azure AI Language (PII Detection) ---
# Used by ChatService to scan user prompts for personally identifiable
# information before invoking the RAG workflow.
#
# RESOURCE:
#   A dedicated "Language service" resource, OR the multi-service Cognitive
#   Services resource above (AISERVICES_COGNITIVE_SERVICES_ENDPOINT can be
#   reused — both expose the /language/:analyze-text endpoint).
#
# AUTHENTICATION:
#   Set PII_ENDPOINT only to use managed identity (recommended).
#   Set PII_API_KEY as an override for local dev.
#
# BEHAVIOUR:
#   PII_ENABLED=true              — scanner runs on every incoming prompt
#   PII_BLOCK_ON_DETECTION=true   — return a canned refusal when PII is found
#                                   (set to false for annotate-only / logging mode
#                                   during a rollout to measure false-positive rate)
#   PII_MIN_CONFIDENCE=0.75       — detections below this score are ignored
#   PII_LANGUAGE=en               — BCP-47 code for the input text
#   PII_REDACT_RESPONSES=false    — when true, also scans the final LLM answer
#                                   and replaces any PII with * before returning
#                                   (defense-in-depth against the model echoing
#                                   sensitive content back)
PII_ENDPOINT=https://<your-language-resource>.cognitiveservices.azure.com/
# PII_API_KEY=<your-language-key>
PII_ENABLED=true
# PII handling mode: block, redact, or detect
PII_MODE=redact
PII_BLOCK_ON_DETECTION=true
PII_MIN_CONFIDENCE=0.75
PII_LANGUAGE=en
PII_REDACT_RESPONSES=false
# Optional: comma-separated list of PII categories to include (leave unset for all)
# PII_CATEGORIES_FILTER=Person,PhoneNumber,Email

# ============================================================================
# WORKFLOW SETTINGS
# ============================================================================
# Tunables for the agentic RAG workflow (retrieval loop, query rewriting,
# reflection, answer generation).

# --- Retrieval loop ---
# Maximum number of search iterations the workflow will perform before giving up
WORKFLOW_MAX_RETRIEVAL_ITERATIONS=3
# Number of recent chat-history messages included as context for the LLM
WORKFLOW_CHAT_HISTORY_WINDOW=5

# --- Query rewriting (HyDE) ---
# Enables HyDE-style query rewriting before semantic search
WORKFLOW_ENABLE_QUERY_REWRITING=true
# Sampling temperature for HyDE hypothetical-passage generation
WORKFLOW_HYDE_TEMPERATURE=0.3
# Maximum tokens for HyDE hypothetical-passage generation
WORKFLOW_HYDE_MAX_TOKENS=500

# --- Reflection agent ---
# Enables the reflection agent that evaluates retrieved-result quality
WORKFLOW_ENABLE_REFLECTION=true
# Valid-result rate (0-1) above which reflection forces an early answer
WORKFLOW_REFLECTION_HIGH_VALIDITY_THRESHOLD=0.8
# Valid-result rate (0-1) for the moderate-validity override
WORKFLOW_REFLECTION_MODERATE_VALIDITY_THRESHOLD=0.6
# Minimum number of valid results required for the moderate-validity override
WORKFLOW_REFLECTION_MODERATE_VALIDITY_MIN_COUNT=3

# --- Answer generation ---
# Sampling temperature used when generating the final answer
WORKFLOW_ANSWER_TEMPERATURE=0.1
